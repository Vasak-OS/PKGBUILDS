# Maintainer: Joaquin (Pato) Decima <jdecima@vasak.net.ar>

pkgname=vasak-gallery
pkgver=0.1.1
pkgrel=1
pkgdesc="A photo gallery application for Vasak OS, built with Tauri and Vue.js."
arch=('x86_64')
url="https://github.com/Vasak-OS/$pkgname"
license=('GPLv3')
depends=(
    'cairo'
    'desktop-file-utils'
    'gdk-pixbuf2'
    'glib2'
    'gtk3'
    'hicolor-icon-theme'
    'libsoup3'
    'pango'
    'webkit2gtk-4.1'
    'dbus'
    'gst-libav'
    'gst-plugins-bad'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugins-ugly'
    'sqlite'
)
makedepends=(
    'git'
    'openssl'
    'appmenu-gtk-module'
    'libappindicator-gtk3'
    'librsvg'
    'cargo'
    'bun'
    'rust'
    'lld'
)
source=("git+${url}.git")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/$pkgname"
    # Instalar dependencias con bun
    bun install
}

build() {
    cd "$srcdir/$pkgname"
  unset CFLAGS
  unset CXXFLAGS
  unset CPPFLAGS
  unset LDFLAGS
  unset RUSTFLAGS
  unset CARGO_BUILD_RUSTFLAGS
  export RUSTFLAGS="-C target-cpu=x86-64 -C target-feature=-sse4a,-avx,-avx2"
  export CARGO_BUILD_RUSTFLAGS="$RUSTFLAGS"
  # Construir el proyecto
    bun run tauri build
}

package() {
    cp -a $srcdir/$pkgname/src-tauri/target/release/bundle/deb/${pkgname}_${pkgver}_*/data/* "${pkgdir}"
}

post_install() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  update-desktop-database -q
}

post_upgrade() {
  post_install
}

post_remove() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  update-desktop-database -q
}
