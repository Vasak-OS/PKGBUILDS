# Maintainer: Joaquin (Pato) Decima <jdecima@vasak.net.ar>

pkgname=vasak-file-manager
pkgver=0.3.0
pkgrel=1
pkgdesc="File manager for VasakOS"
arch=('x86_64')
url="https://github.com/Vasak-OS/$pkgname"
license=('GPLv3')
depends=(
    'cairo'
    'desktop-file-utils'
    'gdk-pixbuf2'
    'glib2'
    'gtk3'
    'hicolor-icon-theme'
    'libsoup'
    'pango'
    'webkit2gtk-4.1'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugins-bad'
    'gst-libav'
    'zstd'
)
makedepends=(
    'git'
    'openssl'
    'appmenu-gtk-module'
    'libappindicator-gtk3'
    'librsvg'
    'cargo'
    'bun'
    'rust'
    'zstd'
)
source=("git+${url}.git")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/$pkgname"
    # Evitar fallos de linking con lld en zstd/tantivy
    mkdir -p src-tauri/.cargo
    cat > src-tauri/.cargo/config.toml << 'EOF'
[target.x86_64-unknown-linux-gnu]
rustflags = [
  "-C",
  "link-arg=-fuse-ld=bfd",
  "-C",
  "link-arg=-Wl,--no-as-needed",
  "-C",
  "link-arg=-lzstd",
]
EOF
    # Instalar dependencias con bun
    bun install
}

build() {
    cd "$srcdir/$pkgname"
    unset CARGO_ENCODED_RUSTFLAGS
    export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=bfd -C link-arg=-Wl,--no-as-needed -C link-arg=-lzstd"
    export RUSTFLAGS="${RUSTFLAGS} -C link-arg=-fuse-ld=bfd -C link-arg=-Wl,--no-as-needed -C link-arg=-lzstd"
    # Construir el proyecto
    bun run tauri build
}

package() {
    cp -a $srcdir/$pkgname/src-tauri/target/release/bundle/deb/${pkgname}_${pkgver}_*/data/* "${pkgdir}"
}

post_install() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  update-desktop-database -q
}

post_upgrade() {
  post_install
}

post_remove() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  update-desktop-database -q
}
