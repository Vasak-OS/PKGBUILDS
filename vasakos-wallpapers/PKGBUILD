# Maintainer: Ali Nabipour <alinabipour01@gmail.com>

pkgname=vasakos-wallpapers
pkgver=0.0.1
pkgrel=1
pkgdesc="VasakOS's system wallpaper"
arch=('any')
url="https://github.com/Vasak-OS/wallpapers"
license=('GPL')
depends=()
provides=("$pkgname")
makedepends=('cmake' 'ninja' 'git')
source=("git+$url.git")
sha512sums=('SKIP')

build() {
  cd wallpapers

  cmake -GNinja -DCMAKE_INSTALL_PREFIX=/usr .
  ninja
}

package() {
  cd wallpapers
  DESTDIR="$pkgdir" ninja install
}
