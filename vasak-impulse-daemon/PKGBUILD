# Maintainer: Joaquin (Pato) Decima <jdecima@vasak.net.ar>

pkgname=vasak-impulse-daemon
pkgver=0.1.0
pkgrel=1
pkgdesc="Keyboard shortcut daemon for VasakOS"
arch=('x86_64' 'aarch64')
url="https://github.com/Vasak-OS/vasak-impulse-daemon"
license=('MIT')
depends=(
    'glibc'
)
makedepends=(
    'cargo'
    'rust'
)
install=${pkgname}.install
source=("git+${url}.git#branch=main")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname"
    cargo build --release --locked
}

package() {
    cd "$srcdir/$pkgname"

    install -Dm755 target/release/$pkgname "$pkgdir/usr/bin/$pkgname"
    install -Dm644 99-vasak-impulse-daemon.rules "$pkgdir/etc/udev/rules.d/99-vasak-impulse-daemon.rules"
    install -Dm644 vasak-impulse-daemon.service "$pkgdir/usr/lib/systemd/system/vasak-impulse-daemon.service"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    #install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
